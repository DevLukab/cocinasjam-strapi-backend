{
  "kind": "collectionType",
  "collectionName": "gallery_tags",
  "info": {
    "singularName": "gallery-tag",
    "pluralName": "gallery-tags",
    "displayName": "Galería-tag"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "order": {
      "type": "integer",
      "unique": true
    },
    "gallery_items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::gallery-item.gallery-item",
      "mappedBy": "gallery_tag"
    }
  }
}
